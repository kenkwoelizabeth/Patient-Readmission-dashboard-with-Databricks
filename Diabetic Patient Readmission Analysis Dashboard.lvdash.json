{
  "datasets": [
    {
      "name": "patient_readmission_metrics",
      "displayName": "Patient Readmission Metrics",
      "config": {
        "source": "SELECT *  FROM patient_readmission_analytics.default.diabetic_encounters WHERE race IS NOT NULL \n  AND race != '?' \n  AND race != 'Unknown'\n  AND medical_specialty IS NOT NULL\n  AND medical_specialty != '?'\n",
        "measures": [
          {
            "name": "encounter_count",
            "expr": "COUNT(*)",
            "displayName": "Total Encounters",
            "comment": "Total number of patient encounters"
          },
          {
            "displayName": "Avg Hospital Stay (days)",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_hospital_stay",
            "expr": "AVG(time_in_hospital)",
            "comment": "Average length of hospital stay in days"
          },
          {
            "displayName": "Avg Medications",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            },
            "name": "avg_medications",
            "expr": "AVG(num_medications)",
            "comment": "Average number of medications administered"
          },
          {
            "displayName": "Avg Procedures",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_procedures",
            "expr": "AVG(num_procedures)",
            "comment": "Average number of procedures performed"
          },
          {
            "displayName": "Avg Lab Procedures",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            },
            "name": "avg_lab_procedures",
            "expr": "AVG(num_lab_procedures)",
            "comment": "Average number of lab procedures"
          }
        ],
        "version": "1.1",
        "comment": "Diabetic patient readmission metrics for analysis (filtered to exclude unknown/invalid values)",
        "dimensions": [
          {
            "name": "age",
            "expr": "age",
            "displayName": "Age Group",
            "comment": "Patient age group bracket"
          },
          {
            "name": "gender",
            "expr": "gender",
            "displayName": "Gender",
            "comment": "Patient gender"
          },
          {
            "name": "race",
            "expr": "race",
            "displayName": "Race",
            "comment": "Patient race"
          },
          {
            "name": "readmitted",
            "expr": "readmitted",
            "displayName": "Readmission Status",
            "comment": "Whether patient was readmitted (NO, <30 days, >30 days)"
          },
          {
            "name": "diag_1",
            "expr": "diag_1",
            "displayName": "Primary Diagnosis",
            "comment": "Primary diagnosis ICD-9 code"
          },
          {
            "name": "medical_specialty",
            "expr": "medical_specialty",
            "displayName": "Medical Specialty",
            "comment": "Medical specialty of the admitting physician"
          }
        ]
      }
    }
  ],
